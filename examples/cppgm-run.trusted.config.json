{
  "baseDir": "/work",
  "workdir": "/work/cppgm-run-trusted",
  "useExistingWorkdir": true,
  "name": "cppgm-run-trusted",
  "testCommand": "make test-report-through-paX",
  "checks": {
    "tests": {
      "command": "make test-report-through-{{testStage}}",
      "primary": true,
      "required": true,
      "kind": "test",
      "excludeStages": [
        "pa39"
      ]
    },
    "fileAudit": {
      "command": "perl scripts/cppgm_file_audit.pl --stage {{testStage}} --paths dev/src",
      "required": true
    },
    "pa39HostThrough38": {
      "command": "make test-report-through-pa38",
      "required": true,
      "kind": "test",
      "targetStage": "pa39",
      "onlyStages": [
        "pa39"
      ]
    },
    "pa39SelfThroughPa10": {
      "command": "make -C pa39 test-through-pa10 CXX=../dev/cppgm++ CPPGM_HOST_CXX=g++",
      "required": true,
      "kind": "generic",
      "targetStage": "pa39",
      "onlyStages": [
        "pa39"
      ]
    },
    "pa39Inception": {
      "command": "make -C pa39 compare-cppgm++-inception CXX=../dev/cppgm++ CPPGM_HOST_CXX=g++",
      "primary": true,
      "required": true,
      "kind": "generic",
      "targetStage": "pa39",
      "onlyStages": [
        "pa39"
      ]
    }
  },
  "phases": [
    {
      "name": "implement",
      "promptTemplate": "implement",
      "goalTemplate": "implement-goal",
      "promptTemplates": {
        "pa39": "pa39-implement"
      },
      "goalTemplates": {
        "pa39": "pa39-implement-goal"
      },
      "checks": [
        "tests",
        "pa39HostThrough38",
        "pa39SelfThroughPa10",
        "pa39Inception",
        "fileAudit"
      ]
    },
    {
      "name": "audit",
      "promptTemplate": "audit",
      "goalTemplate": "audit-goal",
      "promptTemplates": {
        "pa39": "pa39-audit"
      },
      "goalTemplates": {
        "pa39": "pa39-audit-goal"
      },
      "runWhenChecksPass": true,
      "checks": [
        "tests",
        "pa39HostThrough38",
        "pa39SelfThroughPa10",
        "pa39Inception",
        "fileAudit"
      ]
    }
  ],
  "extraStages": [
    "pa39"
  ],
  "maxTurns": 100,
  "stateBaseDir": "/work/.ralph",
  "model": "gpt-5.5",
  "reasoningEffort": "xhigh",
  "sandboxMode": "danger-full-access",
  "approvalPolicy": "never",
  "networkAccessEnabled": true,
  "webSearchEnabled": true,
  "additionalDirectories": [],
  "outputTailChars": 20000,
  "codexPath": "codex",
  "loopGoalsEnabled": true,
  "goalTokenBudget": null,
  "freshThreadPerTurn": true,
  "eventLogScope": "run"
}
